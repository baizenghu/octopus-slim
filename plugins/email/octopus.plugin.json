{
  "id": "enterprise-email",
  "name": "Enterprise Email",
  "description": "提供 send_email 工具，通过 SMTP 发送邮件",
  "version": "1.0.0",
  "configSchema": {
    "type": "object",
    "properties": {
      "smtpHost": {
        "type": "string",
        "description": "SMTP 服务器地址",
        "default": "smtp.qq.com"
      },
      "smtpPort": {
        "type": "number",
        "description": "SMTP 端口",
        "default": 465
      },
      "smtpUser": {
        "type": "string",
        "description": "发件人邮箱"
      },
      "smtpPass": {
        "type": "string",
        "description": "SMTP 授权码"
      },
      "fromName": {
        "type": "string",
        "description": "发件人显示名称",
        "default": "Octopus AI"
      }
    },
    "required": ["smtpUser", "smtpPass"]
  }
}
