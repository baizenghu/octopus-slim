{
  "id": "enterprise-audit",
  "name": "Enterprise Audit",
  "description": "审计 agent 内部行为：tool 调用、LLM 响应、session 生命周期",
  "version": "1.0.0",
  "configSchema": {
    "type": "object",
    "properties": {
      "databaseUrl": {
        "type": "string",
        "description": "MySQL 连接串（Prisma 格式）"
      },
      "logDir": {
        "type": "string",
        "description": "JSONL 审计日志输出目录"
      },
      "retentionDays": {
        "type": "number",
        "description": "日志保留天数",
        "default": 30
      }
    }
  }
}
