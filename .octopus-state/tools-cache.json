    "serverName": "OA办公系统",
    "toolName": "oa_query_leaves",
    "nativeToolName": "mcp_mcp_nocobase_oa_oa_query_leaves",
    "description": "查询请假申请。经理默认看待审批的单据，员工默认看自己的申请。可通过 role_view 切换视角。",
    "inputSchema": {
      "type": "object",
      "properties": {
        "current_user": {
          "type": "string",
          "description": "当前 Octopus 用户名（如 baizh、test），系统自动映射为 OA 用户身份"
        },
        "status": {
          "type": "string",
          "description": "按状态筛选: pending(待审批) / approved(已批准) / rejected(已驳回)",
          "enum": [
            "pending",
            "approved",
            "rejected"
          ]
        },
        "applicant": {
          "type": "string",
          "description": "按申请人筛选（覆盖自动视角）"
        },
        "role_view": {
          "type": "string",
          "description": "查看视角: my_requests(我的申请) / my_approvals(待我审批) / all(全部)",
          "enum": [
            "my_requests",
            "my_approvals",
            "all"
          ]
        }
      },
      "required": [
        "current_user"
      ]
    }
  },
