{
  "meta": {
    "lastTouchedVersion": "1.0.0"
  },
  "browser": {
    "profiles": {
      "remote": {
        "cdpUrl": "http://localhost:9222",
        "color": "#0066CC"
      }
    }
  },
  "models": {
    "providers": {
      "deepseek": {
        "baseUrl": "https://api.deepseek.com/v1",
        "apiKey": "YOUR_DEEPSEEK_API_KEY",
        "api": "openai-completions",
        "models": [
          {
            "id": "deepseek-chat",
            "name": "DeepSeek Chat"
          },
          {
            "id": "deepseek-reasoner",
            "name": "DeepSeek R2"
          }
        ]
      },
      "minimax-portal": {
        "baseUrl": "https://api.minimaxi.com/v1",
        "apiKey": "YOUR_MINIMAX_API_KEY",
        "api": "openai-completions",
        "models": [
          {
            "id": "MiniMax-M2.7",
            "name": "MiniMax M2.7",
            "reasoning": false,
            "input": ["text"],
            "contextWindow": 200000,
            "maxTokens": 8192,
            "compat": {
              "supportsUsageInStreaming": false
            }
          },
          {
            "id": "MiniMax-M2.7-highspeed",
            "name": "MiniMax M2.7 Highspeed",
            "reasoning": true,
            "input": ["text"],
            "contextWindow": 200000,
            "maxTokens": 8192,
            "compat": {
              "supportsUsageInStreaming": false
            }
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "deepseek/deepseek-chat",
        "fallbacks": ["deepseek/deepseek-reasoner"]
      },
      "contextPruning": {
        "mode": "off"
      },
      "compaction": {
        "mode": "safeguard"
      },
      "sandbox": {
        "mode": "all",
        "workspaceAccess": "rw",
        "scope": "agent",
        "docker": {
          "image": "octopus-sandbox:enterprise",
          "binds": [
            "__PROJECT_ROOT__/data/skills:__PROJECT_ROOT__/data/skills:ro"
          ],
          "dangerouslyAllowExternalBindSources": true
        }
      }
    },
    "list": []
  },
  "tools": {
    "loopDetection": {
      "enabled": true,
      "warningThreshold": 8,
      "criticalThreshold": 15,
      "globalCircuitBreakerThreshold": 25
    },
    "exec": {
      "host": "sandbox"
    },
    "fs": {
      "workspaceOnly": true
    },
    "sandbox": {
      "tools": {
        "allow": ["*"],
        "deny": ["browser", "canvas", "nodes", "gateway"]
      }
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "session": {
    "dmScope": "per-channel-peer",
    "maintenance": {
      "mode": "enforce",
      "pruneAfter": "30d",
      "maxEntries": 500
    }
  },
  "skills": {
    "load": {
      "extraDirs": ["__PROJECT_ROOT__/data/skills"],
      "watch": true,
      "watchDebounceMs": 500
    }
  },
  "plugins": {
    "allow": [
      "memory-lancedb-pro",
      "enterprise-audit",
      "enterprise-mcp",
      "enterprise-email"
    ],
    "load": {
      "paths": [
        "__PROJECT_ROOT__/.octopus-state/extensions",
        "__PROJECT_ROOT__/plugins"
      ]
    },
    "slots": {
      "memory": "memory-lancedb-pro"
    },
    "entries": {
      "memory-lancedb-pro": {
        "enabled": true,
        "config": {
          "dbPath": "__PROJECT_ROOT__/.octopus-state/memory/lancedb-pro",
          "embedding": {
            "apiKey": "YOUR_JINA_API_KEY",
            "model": "jina-embeddings-v5-text-small",
            "baseURL": "https://api.jina.ai/v1",
            "dimensions": 1024,
            "taskQuery": "retrieval.query",
            "taskPassage": "retrieval.passage",
            "normalized": true
          },
          "retrieval": {
            "mode": "hybrid",
            "vectorWeight": 0.7,
            "bm25Weight": 0.3,
            "rerank": "cross-encoder",
            "rerankProvider": "jina",
            "rerankEndpoint": "https://api.jina.ai/v1/rerank",
            "rerankModel": "jina-reranker-v3",
            "rerankApiKey": "YOUR_JINA_API_KEY",
            "hardMinScore": 0.3,
            "candidatePoolSize": 20,
            "recencyHalfLifeDays": 14,
            "recencyWeight": 0.1,
            "timeDecayHalfLifeDays": 60,
            "filterNoise": true
          },
          "smartExtraction": true,
          "autoCapture": true,
          "autoRecall": true,
          "scopes": {
            "default": "global"
          },
          "sessionStrategy": "memoryReflection"
        }
      },
      "enterprise-audit": {
        "enabled": true,
        "config": {
          "databaseUrl": "mysql://USER:PASSWORD@localhost:3306/octopus_enterprise",
          "logDir": "__PROJECT_ROOT__/data/audit-logs",
          "retentionDays": 30
        }
      },
      "enterprise-mcp": {
        "enabled": true,
        "config": {
          "databaseUrl": "mysql://USER:PASSWORD@localhost:3306/octopus_enterprise",
          "dataRoot": "__PROJECT_ROOT__/data",
          "sandbox": {
            "mcp": {
              "memory": "256m",
              "cpus": "0.5",
              "network": "octopus-internal"
            },
            "skill": {
              "memory": "512m",
              "cpus": "1",
              "network": "none"
            }
          }
        }
      },
      "enterprise-email": {
        "enabled": true,
        "config": {
          "smtpHost": "smtp.example.com",
          "smtpPort": 465,
          "smtpUser": "your-email@example.com",
          "smtpPass": "YOUR_SMTP_PASSWORD",
          "fromName": "Octopus AI"
        }
      }
    }
  }
}
