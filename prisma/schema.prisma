// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

/// 用户表
model User {
  userId      String    @id @map("user_id") @db.VarChar(64)
  username    String    @unique @db.VarChar(255)
  email       String    @unique @db.VarChar(255)
  displayName String?   @map("display_name") @db.VarChar(255)
  department  String?   @db.VarChar(255)
  roles       Json      /// 角色列表 ["ADMIN","USER"]
  quotas      Json      /// 配额设置
  passwordHash String?  @map("password_hash") @db.VarChar(255) /// MockLDAP 模式下存储密码哈希
  avatarPath  String?   @map("avatar_path") @db.VarChar(512) /// 用户头像文件路径
  status      String    @default("active") @db.VarChar(20)
  ldapDn      String?   @map("ldap_dn") @db.VarChar(512)
  lastLoginAt DateTime? @map("last_login_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  auditLogs AuditLog[]
  sessions  UserSession[]

  @@index([department])
  @@index([status])
  @@map("users")
}

/// 审计日志表
model AuditLog {
  logId        BigInt   @id @default(autoincrement()) @map("log_id")
  userId       String?  @map("user_id") @db.VarChar(64)
  action       String   @db.VarChar(255)
  resource     String?  @db.VarChar(512)
  details      Json?
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  userAgent    String?  @map("user_agent") @db.VarChar(512)
  success      Boolean  @default(true)
  errorMessage String?  @map("error_message") @db.Text
  durationMs   Int?     @map("duration_ms")
  createdAt    DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [userId], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([userId, action, createdAt])
  @@map("audit_logs")
}

/// 用户会话表
model UserSession {
  sessionId String   @id @map("session_id") @db.VarChar(128)
  userId    String   @map("user_id") @db.VarChar(64)
  tokenHash String   @map("token_hash") @db.VarChar(128)
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.VarChar(512)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId])
  @@map("user_sessions")
}

/// 技能表
model Skill {
  id          String   @id @map("skill_id") @db.VarChar(64)
  name        String   @db.VarChar(255)
  description String?  @db.Text
  scope       String   @db.VarChar(20) /// 'enterprise' | 'personal'
  ownerId     String?  @map("owner_id") @db.VarChar(64)
  version     String?  @db.VarChar(20)
  status      String   @default("pending") @db.VarChar(20) /// 'pending'|'approved'|'rejected'
  scriptPath  String?  @map("script_path") @db.VarChar(512) /// 入口脚本相对路径
  command     String?  @db.VarChar(255) /// 执行命令 (python3/node/bash)
  scanReport  Json?    @map("scan_report")
  enabled     Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([scope])
  @@index([ownerId])
  @@map("skills")
}

/// Agent 表（个人级多 Agent）
model Agent {
  id           String   @id @map("agent_id") @db.VarChar(64)
  name         String   @db.VarChar(255)
  description  String?  @db.VarChar(1024)
  ownerId      String   @map("owner_id") @db.VarChar(64)
  model        String?  @db.VarChar(128)   /// 覆盖全局默认模型
  systemPrompt String?  @map("system_prompt") @db.Text /// 自定义系统提示（追加到基础提示后）
  identity     Json?    /// { name?: string, emoji?: string, avatar?: string }
  skillsFilter Json?    @map("skills_filter") /// string[] | null (null=全部可用)
  mcpFilter    Json?    @map("mcp_filter")    /// string[] | null (null=全部可用)
  toolsFilter  Json?    @map("tools_filter")  /// string[] | null (null=全部, "list_files","read_file","write_file")
  allowedConnections Json? @map("allowed_connections") /// string[] | null (null=不限制, 数组=允许的数据库连接名白名单)
  enabled      Boolean  @default(true)
  isDefault    Boolean  @default(false) @map("is_default")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([ownerId])
  @@map("agents")
}

/// MCP 服务表
model MCPServer {
  id          String   @id @map("server_id") @db.VarChar(64)
  name        String   @db.VarChar(255)
  description String?  @db.VarChar(512)
  scope       String   @db.VarChar(20) /// 'enterprise' | 'personal'
  ownerId     String?  @map("owner_id") @db.VarChar(64)
  transport   String   @db.VarChar(20) /// 'stdio' | 'http'
  command     String?  @db.VarChar(512)
  url         String?  @db.VarChar(512)
  args        Json?
  env         Json?
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([scope])
  @@map("mcp_servers")
}

/// IM 通道表
model IMChannel {
  id          String   @id @map("channel_id") @db.VarChar(64)
  name        String   @db.VarChar(255)
  type        String   @db.VarChar(20) /// 'igw' | 'wxt'
  webhookUrl  String?  @map("webhook_url") @db.VarChar(512)
  botToken    String?  @map("bot_token") @db.VarChar(512)
  config      Json?
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("im_channels")
}

/// IM 用户绑定表
model IMUserBinding {
  id          String   @id @map("binding_id") @db.VarChar(64)
  userId      String   @map("user_id") @db.VarChar(64)
  channel     String   @db.VarChar(20)
  imUserId    String   @map("im_user_id") @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([channel, imUserId])
  @@index([userId])
  @@map("im_user_bindings")
}

/// 定时任务表
model ScheduledTask {
  id          String   @id @map("task_id") @db.VarChar(64)
  name        String   @db.VarChar(255)
  userId      String   @map("user_id") @db.VarChar(64)
  cron        String   @db.VarChar(64)
  taskType    String   @map("task_type") @db.VarChar(20) /// 'skill'|'mcp'|'report'|'mail'
  taskConfig  Json     @map("task_config")
  enabled     Boolean  @default(true)
  lastRunAt   DateTime? @map("last_run_at")
  nextRunAt   DateTime? @map("next_run_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("scheduled_tasks")
}

/// 邮件日志表
model MailLog {
  id          String   @id @map("log_id") @db.VarChar(64)
  userId      String   @map("user_id") @db.VarChar(64)
  to          String   @db.Text
  subject     String   @db.VarChar(255)
  status      String   @db.VarChar(20) /// 'sent' | 'failed'
  error       String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("mail_logs")
}

/// 数据库连接配置表
model DatabaseConnection {
  id          String   @id @map("connection_id") @db.VarChar(64)
  userId      String   @map("user_id") @db.VarChar(64)
  name        String   @db.VarChar(255)  /// 连接名称，用于生成 DB_{name}_xxx 环境变量
  dbType      String   @map("db_type") @db.VarChar(20) /// 'mysql' | 'postgres' | 'sqlite'
  host        String   @db.VarChar(255)
  port        Int
  dbUser      String   @map("db_user") @db.VarChar(255)
  dbPassword  String   @map("db_password") @db.VarChar(512)
  dbName      String   @map("db_name") @db.VarChar(255)
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([userId, name])
  @@index([userId])
  @@map("database_connections")
}

/// 生成文件注册表（文件生命周期管理）
model GeneratedFile {
  id          String   @id @map("file_id") @db.VarChar(512)  /// 确定性 ID: {userId}:outputs/{relPath}
  userId      String   @map("user_id") @db.VarChar(64)
  category    String   @db.VarChar(20)  /// 'output' | 'temp' | 'upload'
  filePath    String   @map("file_path") @db.VarChar(1024)  /// 相对于 workspace 的路径
  fileSize    Int      @map("file_size")  /// 字节
  skillId     String?  @map("skill_id") @db.VarChar(64)  /// 产生该文件的 Skill ID
  agentName   String?  @map("agent_name") @db.VarChar(255)  /// 产生该文件的 Agent
  createdAt   DateTime @default(now()) @map("created_at")
  expiresAt   DateTime @map("expires_at")  /// 根据 category 计算
  status      String   @default("active") @db.VarChar(20)  /// 'active' | 'expired' | 'deleted'

  @@index([userId])
  @@index([status, expiresAt])
  @@index([userId, category])
  @@map("generated_files")
}
