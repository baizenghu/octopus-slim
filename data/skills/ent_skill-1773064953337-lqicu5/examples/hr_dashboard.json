{
    "title": "人力资源数据分析",
    "description": "HR 仪表盘配置示例，包含员工统计、部门分布、薪资分析等",
    "charts": [
        {
            "type": "kpi",
            "title": "员工总数",
            "measures": [
                "员工ID"
            ],
            "config": {
                "agg": "count"
            }
        },
        {
            "type": "kpi",
            "title": "平均薪资",
            "measures": [
                "薪资"
            ],
            "config": {
                "agg": "mean",
                "format": ",.0f"
            }
        },
        {
            "type": "kpi",
            "title": "平均工龄",
            "measures": [
                "工龄"
            ],
            "config": {
                "agg": "mean",
                "format": ".1f"
            }
        },
        {
            "type": "kpi",
            "title": "离职率",
            "measures": [
                "离职标记"
            ],
            "config": {
                "agg": "mean",
                "format": ".2%"
            }
        },
        {
            "type": "bar",
            "title": "部门人数分布",
            "dimensions": [
                "部门"
            ],
            "measures": [
                "员工ID"
            ],
            "config": {
                "horizontal": false
            }
        },
        {
            "type": "pie",
            "title": "学历占比",
            "dimensions": [
                "学历"
            ],
            "measures": [
                "员工ID"
            ],
            "config": {
                "donut": true
            }
        },
        {
            "type": "bar",
            "title": "各部门平均薪资",
            "dimensions": [
                "部门"
            ],
            "measures": [
                "薪资"
            ],
            "col_span": 6
        },
        {
            "type": "line",
            "title": "入职趋势",
            "dimensions": [
                "入职年份"
            ],
            "measures": [
                "员工ID"
            ],
            "config": {
                "smooth": true
            },
            "col_span": 6
        }
    ]
}